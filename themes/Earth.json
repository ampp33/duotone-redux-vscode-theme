                "support.variable.dom"
            ],
            "settings": {
                "foreground": "#98755d"
            }
        },
        {
            "name": "HTML Text",
            "scope": "text.html",
            "settings": {
                "foreground": "#705e51"
            }
        },
        {
            "name": "CSS Source Base",
            "scope": "source.css",
            "settings": {
                "foreground": "#564b43"
            }
        },
        {
            "name": "CSS Unit",
            "scope": "keyword.other.unit",
            "settings": {
                "foreground": "#b09045"
            }
        },
        {
            "name": "CSS Function",
            "scope": [
                "support.function.css",
