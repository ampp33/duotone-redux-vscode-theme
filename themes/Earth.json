            }
        },
        {
            "name": "JSON Constant",
            "scope": "constant.language.json",
            "settings": {
                "foreground": "#b09045"
            }
        },
        {
            "name": "YAML Tag",
            "scope": "entity.name.tag.yaml",
            "settings": {
