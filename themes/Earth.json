    "tokenColors": [
        {
            "name": "Comment",
            "scope": "comment",
            "settings": {
                "foreground": "#564b43",
                "fontStyle": " italic"
            }
        },
        {
            "name": "Comment in Params",
            "scope": "meta.parameters comment.block",
            "settings": {
                "foreground": "#726546",
                "fontStyle": " italic"
            }
        },
        {
            "name": "String",
            "scope": "string",
            "settings": {
                "foreground": "#fecb52"
            }
        },
        {
            "name": "Number",
            "scope": "constant.numeric",
            "settings": {
                "foreground": "#fecb52"
            }
        },
        {
            "name": "Built-in constant",
            "scope": "constant.language",
            "settings": {
                "foreground": "#fecb52"
            }
        },
        {
            "name": "User-defined constant",
            "scope": [
                "constant.character",
                "constant.other"
            ],
            "settings": {
                "foreground": "#fecb52"
            }
        },
        {
            "name": "Constant variable",
            "scope": "variable.other.constant",
            "settings": {
                "foreground": "#bd987f"
            }
        },
        {
            "name": "Variable",
            "scope": [
                "variable",
                "support.other.variable"
            ],
            "settings": {
                "fontStyle": "",
                "foreground": "#bd987f"
            }
        },
        {
            "name": "Keyword",
            "scope": "keyword",
            "settings": {
                "foreground": "#b09045"
            }
        },
        {
            "name": "Storage",
            "scope": "storage",
            "settings": {
                "fontStyle": "",
                "foreground": "#b09045"
            }
        },
        {
            "name": "Storage type",
            "scope": "storage.type",
            "settings": {
                "fontStyle": "italic",
                "foreground": "#b09045"
            }
        },
        {
            "name": "Arrow function",
            "scope": "storage.type.function.arrow",
            "settings": {
                "fontStyle": "",
                "foreground": "#fecb52"
            }
        },
        {
            "name": "Class name",
            "scope": "entity.name.class",
            "settings": {
                "fontStyle": "underline",
                "foreground": "#ffdac2"
            }
        },
        {
            "name": "Type Name",
            "scope": "support.type",
            "settings": {
                "fontStyle": "",
                "foreground": "#ffdac2"
            }
        },
        {
