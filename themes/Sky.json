    "tokenColors": [
        {
            "name": "Comment",
            "scope": "comment",
            "settings": {
                "foreground": "#544d60",
                "fontStyle": " italic"
            }
        },
        {
            "name": "Comment in Params",
            "scope": "meta.parameters comment.block",
            "settings": {
                "foreground": "#765f4c",
                "fontStyle": " italic"
            }
        },
        {
            "name": "String",
            "scope": "string",
            "settings": {
