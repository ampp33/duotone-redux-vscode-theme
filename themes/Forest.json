    "tokenColors": [
        {
            "name": "Comment",
            "scope": "comment",
            "settings": {
                "foreground": "#585f58",
                "fontStyle": " italic"
            }
        },
        {
            "name": "Comment in Params",
            "scope": "meta.parameters comment.block",
            "settings": {
                "foreground": "#747a52",
                "fontStyle": " italic"
            }
        },
        {
            "name": "String",
            "scope": "string",
            "settings": {
