            }
        },
        {
            "name": "JSON Constant",
            "scope": "constant.language.json",
            "settings": {
                "foreground": "#b06845"
            }
        },
        {
            "name": "YAML Tag",
            "scope": "entity.name.tag.yaml",
            "settings": {
                "foreground": "#8686cb"
            }
        },
        {
            "name": "YAML Constant",
            "scope": "constant.language.yaml",
            "settings": {
                "foreground": "#b06845"
            }
        },
        {
            "name": "Markdown Bold",
