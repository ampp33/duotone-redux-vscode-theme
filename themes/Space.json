    "tokenColors": [
        {
            "name": "Comment",
            "scope": "comment",
            "settings": {
                "foreground": "#49495a",
                "fontStyle": " italic"
            }
        },
        {
            "name": "Comment in Params",
            "scope": "meta.parameters comment.block",
            "settings": {
                "foreground": "#644c40",
                "fontStyle": " italic"
            }
        },
        {
            "name": "String",
            "scope": "string",
            "settings": {
                "foreground": "#fe7734"
            }
        },
        {
            "name": "Number",
            "scope": "constant.numeric",
            "settings": {
                "foreground": "#fe7734"
            }
        },
        {
            "name": "Built-in constant",
            "scope": "constant.language",
            "settings": {
                "foreground": "#fe7734"
            }
        },
        {
            "name": "User-defined constant",
            "scope": [
                "constant.character",
                "constant.other"
            ],
            "settings": {
                "foreground": "#fe7734"
            }
        },
        {
            "name": "Constant variable",
            "scope": "variable.other.constant",
            "settings": {
                "foreground": "#8686cb"
            }
        },
        {
            "name": "Variable",
            "scope": [
                "variable",
                "support.other.variable"
            ],
            "settings": {
                "fontStyle": "",
                "foreground": "#8686cb"
            }
        },
        {
            "name": "Keyword",
            "scope": "keyword",
            "settings": {
                "foreground": "#b06845"
            }
        },
        {
            "name": "Storage",
            "scope": "storage",
            "settings": {
                "fontStyle": "",
                "foreground": "#b06845"
            }
        },
        {
            "name": "Storage type",
            "scope": "storage.type",
            "settings": {
                "fontStyle": "italic",
                "foreground": "#b06845"
            }
        },
        {
            "name": "Arrow function",
            "scope": "storage.type.function.arrow",
            "settings": {
                "fontStyle": "",
                "foreground": "#fe7734"
            }
        },
        {
            "name": "Class name",
            "scope": "entity.name.class",
            "settings": {
                "fontStyle": "underline",
                "foreground": "#bebeef"
            }
        },
        {
            "name": "Type Name",
            "scope": "support.type",
            "settings": {
                "fontStyle": "",
                "foreground": "#bebeef"
            }
        },
        {
            "name": "Entity type name",
            "scope": "entity.name.type",
            "settings": {
                "fontStyle": "",
                "foreground": "#fe7734"
            }
        },
        {
            "name": "Module/namespace name",
            "scope": "entity.name.type.module",
            "settings": {
                "fontStyle": "",
                "foreground": "#5b5b7b"
            }
        },
        {
            "name": "Inherited class",
            "scope": "entity.other.inherited-class",
            "settings": {
                "fontStyle": "italic underline",
                "foreground": "#bebeef"
            }
        },
        {
            "name": "Function name",
            "scope": "entity.name.function",
            "settings": {
                "fontStyle": "",
                "foreground": "#5b5b7b"
            }
        },
        {
            "name": "Function argument",
            "scope": "variable.parameter",
            "settings": {
                "fontStyle": "italic",
                "foreground": "#7272a1"
            }
        },
        {
            "name": "Tag name",
            "scope": [
                "entity.name.tag",
                "entity.other.attribute-name.class",
